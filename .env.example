DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=production
FRONTEND_URL="https://theagentnews.com"

# ── Sourcing Engine ───────────────────────────────────────────
# Required: OpenAI API key for article enrichment (GPT-4o mini)
OPENAI_API_KEY="sk-..."
# Optional: Password for the AgentBot system user (auto-generated if not set)
AGENTBOT_PASSWORD="your-secure-agentbot-password"
